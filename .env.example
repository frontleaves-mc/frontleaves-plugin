# ============================================
# Application
# ============================================
XLF_DEBUG=true
XLF_HOST=0.0.0.0
XLF_PORT=8080
APP_NAME=bamboo-base-go-template
APP_VERSION=v0.1.0

# ============================================
# PostgreSQL
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=frontleaves-plugin
DATABASE_PASS=frontleaves-plugin
DATABASE_NAME=frontleaves-plugin
DATABASE_PREFIX=fp_
DATABASE_TIMEZONE=Asia/Shanghai

# ============================================
# Redis
# ============================================
NOSQL_HOST=localhost
NOSQL_PORT=6379
NOSQL_PASS=
NOSQL_DATABASE=1
NOSQL_PREFIX=tpl:
NOSQL_POOL_SIZE=100

# ============================================
# Snowflake (Optional)
# ============================================
SNOWFLAKE_DATACENTER_ID=1
SNOWFLAKE_NODE_ID=1

# ============================================
# gRPC Yggleaf
# ============================================
YGGLEAF_GRPC_HOST=localhost
YGGLEAF_GRPC_PORT=5578
