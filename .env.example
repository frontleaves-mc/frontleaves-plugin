# ============================================
# Application
# ============================================
XLF_DEBUG=true
XLF_HOST=0.0.0.0
XLF_PORT=8080
APP_NAME=bamboo-base-go-template
APP_VERSION=v0.1.0

# ============================================
# PostgreSQL
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=frontleaves-plugin
DATABASE_PASS=frontleaves-plugin
DATABASE_NAME=frontleaves-plugin
DATABASE_PREFIX=fp_
DATABASE_TIMEZONE=Asia/Shanghai

# ============================================
# Redis
# ============================================
NOSQL_HOST=localhost
NOSQL_PORT=6379
NOSQL_PASS=
NOSQL_DATABASE=1
NOSQL_PREFIX=tpl:
NOSQL_POOL_SIZE=100

# ============================================
# Snowflake (Optional)
# ============================================
SNOWFLAKE_DATACENTER_ID=1
SNOWFLAKE_NODE_ID=1

# ============================================
# gRPC Yggleaf
# ============================================
YGGLEAF_GRPC_HOST=localhost
YGGLEAF_GRPC_PORT=5578
YGGLEAF_GRPC_SECRET_KEY=-

# ============================================
# Matrix 遥测 (Optional)
# ============================================
# manageLoop 轮询间隔，Go duration 格式，默认 5s
MATRIX_MANAGE_INTERVAL=5s

# ============================================
# Matrix Anti-Cheat (Optional)
# ============================================
# 反作弊总开关，默认 true
MATRIX_AC_ENABLED=true

# Speed（速度检测）
MATRIX_AC_SPEED_BASE_SPEED=4.317         # 基础移动速度阈值（blocks/tick）
MATRIX_AC_SPEED_TOLERANCE=0.15           # 速度容忍度浮动范围
MATRIX_AC_SPEED_VL_THRESHOLD=5.0         # 速度违规 Violation Level 阈值

# Reach（攻击距离检测）
MATRIX_AC_REACH_MAX_REACH=3.0            # 最大攻击距离（blocks）
MATRIX_AC_REACH_EXPAND=0.1               # 扩展攻击距离（blocks）
MATRIX_AC_REACH_VL_THRESHOLD=3.0         # 攻击距离违规 Violation Level 阈值

# Timer（计时器异常检测）
MATRIX_AC_TIMER_CLOCK_DRIFT=150          # 时钟漂移容忍度（ms）
MATRIX_AC_TIMER_VL_THRESHOLD=5.0         # Timer 违规 Violation Level 阈值

# Fly（飞行检测）
MATRIX_AC_FLY_VL_THRESHOLD=5.0           # 飞行违规 Violation Level 阈值
MATRIX_AC_FLY_HOVER_THRESHOLD=40         # 悬停违规判定阈值（ticks）

# Xray（透视检测）
MATRIX_AC_XRAY_WINDOW_SIZE=100           # 检测窗口大小（样本数）
MATRIX_AC_XRAY_DIAMOND_RATIO=0.05        # 钻石采集异常阈值
MATRIX_AC_XRAY_EMERALD_RATIO=0.03        # 绿宝石采集异常阈值
MATRIX_AC_XRAY_ANCIENT_RATIO=0.01        # 远古遗迹采集异常阈值

# KillAura（自动攻击检测）
MATRIX_AC_KILLAURA_WINDOW_MS=3000        # 检测时间窗口（ms）
MATRIX_AC_KILLAURA_MAX_SWITCH=3          # 最大切换目标次数
MATRIX_AC_KILLAURA_ANGLE_THRESHOLD=90.0  # 角度异常阈值（度）

# Aimbot（自瞄检测）
MATRIX_AC_AIMBOT_SAMPLE_WINDOW=30        # 采样窗口大小（样本数）
MATRIX_AC_AIMBOT_SENSITIVITY_DELTA=0.15  # 灵敏度变化阈值

# AutoClicker（自动连点检测）
MATRIX_AC_AUTOCLICKER_MAX_CPS=16         # 最大 CPS 阈值
MATRIX_AC_AUTOCLICKER_WINDOW_MS=1000     # 检测时间窗口（ms）
MATRIX_AC_AUTOCLICKER_MIN_STDDEV=15.0    # 最小标准差阈值

# Fastbreak（快速破坏检测）
MATRIX_AC_FASTBREAK_WINDOW_SIZE=20       # 检测窗口大小（样本数）
MATRIX_AC_FASTBREAK_RATIO_THRESHOLD=0.5  # 破坏比例阈值

# NoFall（无掉落伤害检测）
MATRIX_AC_NOFALL_FALL_SPEED=0.1          # 下落速度阈值（blocks/tick）
MATRIX_AC_NOFALL_CONSECUTIVE_TICKS=3     # 连续无伤害下落判定阈值（ticks）

# ============================================
# gRPC Server
# ============================================
GRPC_PORT=1119
GRPC_REFLECTION=true

# ============================================
# Email Configuration
# ============================================
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=FrontLeaves
EMAIL_FROM_ADDRESS=noreply@example.com
